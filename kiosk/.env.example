# Kiosk veb-ilova (Nuxt) sozlamalari — nusxa oling: cp .env.example .env
#
# Python (FastAPI) server manzili. TLS yoqiq bo'lsa (standart) https, aks holda
# (server KIOSK_TLS=0 bilan ishga tushirilgan bo'lsa) http.
NUXT_KIOSK_SERVER=https://127.0.0.1:8765

# Server API kaliti — server admin oynasining Boshqaruv sahifasidan olinadi
# ("Nusxalash"). Bo'sh qoldirilsa kalitsiz so'rovlar ketadi (server rad etadi).
NUXT_KIOSK_API_KEY=
